# CareerPilot AI — environment variables
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).

# ---- Core ----
CAREERPILOT_ENV=development            # development | testing | production
CAREERPILOT_DEBUG=true

# ---- Database ----
# Async driver URLs. SQLite is the zero-config default for local dev/tests.
CAREERPILOT_DATABASE_URL=sqlite+aiosqlite:///./careerpilot.db
# Production example (PostgreSQL):
# CAREERPILOT_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/careerpilot

# ---- Security ----
# Fernet key used to encrypt secrets at rest (SMTP passwords, API keys).
# Generate with: python -m careerpilot.backend.core.security generate-key
CAREERPILOT_ENCRYPTION_KEY=

# ---- LLM provider (used from Module 8 onward) ----
CAREERPILOT_LLM_PROVIDER=openai
CAREERPILOT_OPENAI_API_KEY=

# ---- Email providers (used from Module 15 onward) ----
CAREERPILOT_SMTP_HOST=
CAREERPILOT_SMTP_PORT=587
CAREERPILOT_SMTP_USERNAME=
CAREERPILOT_SMTP_PASSWORD=
